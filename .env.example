# Trading Tazos Game — Environment Configuration
# Copy this file to .env and fill in your values
DATABASE_URL="file:./prisma/dev.db"

# Auth — REQUIRED: generate a strong 64-char random secret
# Example: openssl rand -base64 64
JWT_SECRET="generate-a-random-64-char-secret-here"

# Domain & Branding
NEXT_PUBLIC_DOMAIN=your-domain.com
NEXT_PUBLIC_SITE_NAME="Trading Tazos Game"
NEXT_PUBLIC_CONTACT_EMAIL=support@your-domain.com

# Deployment
NEXT_PUBLIC_BASE_URL=https://your-domain.com
PORT=3000
WS_PORT=3001
WS_HOST=0.0.0.0

# AdSense — set to "true" to enable Google AdSense (requires approved publisher ID)
NEXT_PUBLIC_ADSENSE_ENABLED=false
