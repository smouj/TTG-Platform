# ttg-artgen — OpenAI API Configuration
# Copy this file to .env and fill in your key:
#   cp artgen/.env.example .env

OPENAI_API_KEY=sk-your-key-here

# Optional: model override (default: gpt-image-2)
IMAGE_MODEL=gpt-image-2

# Optional: image size (1024x1024, 1792x1024, 1024x1792)
IMAGE_SIZE=1024x1024

# Optional: quality (standard, high)
IMAGE_QUALITY=high
