      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3001,
        "WS_PORT": 3001,
        "JWT_SECRET": "${JWT_SECRET}"
      },
      "max_memory_restart": "256M",
      "restart_delay": 3000,
      "max_restarts": 10,
